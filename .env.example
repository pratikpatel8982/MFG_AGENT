# ─── LLM ────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── SEARCH APIs (optional — DuckDuckGo used as free fallback) ───────
TAVILY_API_KEY=tvly-your_key_here
SERPER_API_KEY=your_serper_key_here

# ─── FIREBASE (Google Sign-In) ───────────────────────────────────────
# Save your service account JSON as: backend/firebase_key.json
# Download from: Firebase Console → Project Settings → Service Accounts
#                → Generate new private key
# (this file is gitignored — never commit it)

# ─── CHROMADB ────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data
# For ChromaDB Cloud (optional):
# CHROMA_HOST=https://your-chroma-cloud-host
# CHROMA_API_KEY=your-chroma-cloud-key

# ─── SCRAPER TUNING ──────────────────────────────────────────────────
# Max search results per query (DuckDuckGo / Tavily / Serper)
MAX_RESULTS=10
# Max pages to deep-scrape per run (more = richer but slower)
SCRAPE_LIMIT=5
# HTTP timeout per request (seconds)
TIMEOUT=12

# ─── SERVER ──────────────────────────────────────────────────────────
PORT=5000
HOST=0.0.0.0
DEBUG=false

# ─── CORS ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your Vercel frontend URL)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
